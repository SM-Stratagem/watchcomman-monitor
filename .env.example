# ─────────────────────────────────────────────────────────────────────────────
# Core (required for production)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/db
CRON_SECRET=replace-me-with-a-random-string
SITE_URL=https://www.monitor-info.app

# ─────────────────────────────────────────────────────────────────────────────
# AI (optional — enables real World Brief auto-summaries)
# Set ANTHROPIC_API_KEY (preferred — uses Claude Haiku 4.5) OR OPENAI_API_KEY.
# Without either, the AI brief falls back to the top convergent headline.
# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# News APIs (optional — each adds significantly more news coverage)
# All have free tiers; the platform fetches from whichever you provide.
# ─────────────────────────────────────────────────────────────────────────────
# NEWSAPI_KEY=          # newsapi.org — 100 req/day free, 12 countries × top-headlines
# GNEWS_KEY=            # gnews.io — 100 req/day free, 6 topics × top-headlines
# MEDIASTACK_KEY=       # mediastack.com — 500/mo free, 100 articles latest
# THENEWSAPI_KEY=       # thenewsapi.com — 500/mo free, 50 articles top
# NEWSDATA_KEY=         # newsdata.io — 200/mo free, 50 articles latest

# ─────────────────────────────────────────────────────────────────────────────
# OpenSky Network (optional — boosts flight tracking rate limit)
# Without these, anonymous ~100 req/day is used. With auth ~4000/day.
# Register free at https://opensky-network.org/
# ─────────────────────────────────────────────────────────────────────────────
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# GitHub (optional — boosts GitHub trending API rate limit from 60 to 5000/hr)
# Personal access token; needs no scopes
# ─────────────────────────────────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_...

# ─────────────────────────────────────────────────────────────────────────────
# Sibling monitors (optional)
# ─────────────────────────────────────────────────────────────────────────────
# EBOLA_MONITOR_FEED_URL=https://www.ebolamonitorapp.com/api/feed.json
# HANTA_MONITOR_FEED_URL=https://hantavirus-monitor.up.railway.app/api/feed.json

# ─────────────────────────────────────────────────────────────────────────────
# Defense-grade feeds (optional — each enables one Tier 1/2 source)
# ─────────────────────────────────────────────────────────────────────────────
# ACLED (Armed Conflict Location & Event Data) — register free at acleddata.com
# ACLED_API_KEY=
# ACLED_EMAIL=

# SAM.gov contract opportunities — register free at open.gsa.gov/api/get-opportunities-public-api
# SAM_API_KEY=

# NIST NVD CVE feed — works keyless but is rate-limited; key bumps quota.
# Register at nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Optional auth gates (defense / enterprise deployments)
# ─────────────────────────────────────────────────────────────────────────────
# BASIC_AUTH_USER + BASIC_AUTH_PASSWORD — if BOTH set, the entire UI requires
# HTTP basic auth. Leave unset for public deployment.
# BASIC_AUTH_USER=
# BASIC_AUTH_PASSWORD=

# API_KEY — if set, /api/v1/* routes require X-API-Key header (or ?api_key=).
# Leave unset to keep the public API open.
# API_KEY=
